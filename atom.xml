  <entry>
    <title>文章资源test</title>
    <link href="http://yoursite.com/2019/02/15/%E6%96%87%E7%AB%A0%E8%B5%84%E6%BA%90test/"/>
    <id>http://yoursite.com/2019/02/15/文章资源test/</id>
